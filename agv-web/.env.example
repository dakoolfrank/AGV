# ════════════════════════════════════════════════════════════════════
# AGV Web — 统一环境变量模板 (Vercel / 本地开发共用)
# ════════════════════════════════════════════════════════════════════
#
# 使用方法:
#   1. 复制到各子项目: cp .env.example <project>/.env.local
#   2. 或在 Vercel Dashboard → Settings → Environment Variables 中逐个填入
#   3. 每个项目只需配置自己用到的变量（见下方 §模块依赖矩阵）
#
# ⚠️ 安全规则:
#   - .env.local 已 gitignored，绝对不要提交
#   - FIREBASE_PRIVATE_KEY 在 Vercel 中必须用单行 \n 转义格式
#   - NEXT_PUBLIC_ 前缀的变量会暴露到浏览器，因此只放公开配置
#
# ═══════════════════════════════════════════════════════════════════
# 模块依赖矩阵 — 哪个项目需要哪些变量
# ═══════════════════════════════════════════════════════════════════
#
#   变量组                  | protocol | investor | buy-page | G3-Fund | asset | arch | taskon
#   ─── Firebase Admin ─── |    ✅    |    ✅    |    ✅    |   ✅   |  ✅  |  —  |   —
#   ─── Firebase Client ── |    ✅    |    ✅    |    ✅¹   |   ✅   |  ✅  |  —  |   —
#   ─── Thirdweb ───────── |    ✅    |    —     |    ✅    |   ✅   |  —   |  ✅ |   —
#   ─── Redis (Upstash) ── |    ✅    |    —     |    —     |   ✅   |  —   |  —  |   —
#   ─── Moralis ────────── |    ✅    |    —     |    ✅²   |   —    |  —   |  —  |   —
#   ─── Email (Brevo) ──── |    —     |    ✅    |    ✅    |   —    |  —   |  —  |   —
#   ─── Discord OAuth ──── |    —     |    —     |    ✅    |   —    |  —   |  —  |   —
#   ─── Maps ───────────── |    —     |    —     |    —     |   —    |  ✅  |  —  |   —
#   ─── Notion + Tally ─── |    —     |    —     |    —     |   —    |  —   |  —  |   ✅
#   ─── Twitter ────────── |    ✅³   |    —     |    —     |   —    |  —   |  —  |   —
#   ─── Airdrop Badge ──── |    —     |    —     |    ✅    |   —    |  —   |  —  |   —
#   ─── Translation ────── |    ✅    |    ✅    |    ✅    |   —    |  ✅  |  —  |   —
#   ─── Site URL ───────── |    ✅    |    ✅    |    ✅    |   ✅   |  ✅  |  ✅ |   —
#
#   ¹ buy-page 仅用 NEXT_PUBLIC_FIREBASE_PROJECT_ID（客户端 6 个中的 1 个）
#   ² buy-page 用 NEXT_PUBLIC_MORALIS_API_KEY（前端公开版）
#   ³ agv-protocol-app 用于社交验证
#
# ═══════════════════════════════════════════════════════════════════
# 信息流向 — 理解各服务如何串联
# ═══════════════════════════════════════════════════════════════════
#
#  ┌───────────────────────────────────────────────────────────────┐
#  │                     用户浏览器                                 │
#  │  Firebase Client SDK ──→ Auth (登录/注册) + Firestore (数据)  │
#  │  Thirdweb SDK ────────→ 钱包连接 → BSC 合约交互               │
#  │  Moralis SDK ─────────→ 链上数据索引 (NFT/Token 余额)         │
#  └───────────────────┬───────────────────────────────────────────┘
#                      │ HTTPS
#  ┌───────────────────▼───────────────────────────────────────────┐
#  │                  Vercel SSR / API Routes                       │
#  │  Firebase Admin SDK ──→ 服务端用户验证 + 数据读写              │
#  │  Upstash Redis ───────→ 速率限制 + Session 缓存               │
#  │  Brevo API ───────────→ 邮件通知 (注册确认/空投通知)           │
#  │  Notion API ──────────→ TaskOn 验证数据查询                    │
#  │  Discord OAuth ───────→ 空投资格验证 (社区身份)                │
#  └───────────────────────────────────────────────────────────────┘
#
# ═══════════════════════════════════════════════════════════════════

# ─── ① Firebase Admin SDK（服务端，3 个 — build 必需）──────────
# 来源: Firebase Console → Project Settings → Service Accounts → Generate new private key
# ⚠️ FIREBASE_PRIVATE_KEY 必须单行 \n 格式，否则 Vercel build 报 Invalid PEM
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── ② Firebase Client SDK（浏览器端，6 个 — NEXT_PUBLIC_ 前缀公开）─
# 来源: Firebase Console → Project Settings → General → Web app → firebaseConfig
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── ③ Thirdweb（Web3 钱包连接）──────────────────────────────
# 来源: Thirdweb Dashboard → API Keys → Client ID
# CLIENT_ID 是公开的（NEXT_PUBLIC_ 前缀），SECRET 仅服务端使用
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
NEXT_PUBLIC_THIRDWEB_SECRET_KEY=

# ─── ④ Upstash Redis（缓存 + 速率限制）──────────────────────
# 来源: Upstash Console → Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── ⑤ Moralis（链上数据索引 — NFT/Token 余额查询）──────────
# 来源: Moralis Dashboard → API Keys
MORALIS_API_KEY=
NEXT_PUBLIC_MORALIS_API_KEY=

# ─── ⑥ Email 通知（Brevo / 原 Sendinblue）──────────────────
# 来源: Brevo Dashboard → SMTP & API → API Keys
BREVO_API_KEY=

# ─── ⑦ Discord OAuth（空投资格验证）─────────────────────────
# 来源: Discord Developer Portal → Applications → OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=

# ─── ⑧ 空投徽章合约（buy-page 专用）────────────────────────
# BSC 链上 ERC1155 空投徽章合约地址
NEXT_PUBLIC_AIRDROP_BADGE_CONTRACT=

# ─── ⑨ Notion + Tally（TaskOn 验证 API 专用）────────────────
# 来源: Notion Integrations / Tally Dashboard
NOTION_TOKEN=
NOTION_DB_ID=
TALLY_API_KEY=
TALLY_FORM_ID=

# ─── ⑩ Twitter / X（社交验证）───────────────────────────────
# 来源: Twitter Developer Portal → Bearer Token
TWITTER_BEARER_TOKEN=

# ─── ⑪ Maps / 地理服务（asset 项目专用）─────────────────────
# 来源: Google Cloud Console / OpenCage / 高德开放平台
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NEXT_PUBLIC_AMAP_KEY=
NEXT_PUBLIC_OPENCAGE_KEY=
OPENCAGE_API_KEY=

# ─── ⑫ 翻译服务 ─────────────────────────────────────────────
TRANSLATION_PROVIDER=google
TRANSLATION_API_KEY=

# ─── ⑬ 站点 URL ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://agvnexrur.ai

# ─── ⑭ Cron 任务密钥（buy-page 专用）───────────────────────
CRON_SECRET=

# ─── ⑮ 管理员配置（agv-protocol-app 专用）──────────────────
ADMIN_KEY=
ADMIN_MIGRATE_KEY=
ADMIN_SUPER_ADMINS=
MERKLE_ROOT=
PROOFS_JSON_PATH=
WL_CACHE_TTL_MS=