# ============================================
# AGV Token Deployment Configuration
# ============================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to Git!
# ============================================

# Deployment — your deployer wallet private key (with 0x prefix)
PRIVATE_KEY=0x_your_deployer_private_key_here

# RPC URLs
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
BSC_RPC_URL=https://bsc-dataseed1.binance.org
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Block Explorer API Keys (for contract verification on BscScan/Arbiscan)
BSCSCAN_API_KEY=your_bscscan_api_key
ARBISCAN_API_KEY=your_arbiscan_api_key

# Optional: Mainnet specific
ADMIN_ADDRESS=0x...      # Admin multisig address
MULTISIG_ADDRESS=0x...   # Multisig address

# ============================================
# AirdropMint.s.sol — Step 1: Deploy + Mint
# ============================================
# Target wallet to receive 1M pGVT + 1M sGVT
AIRDROP_TO=0x_your_wallet_address_here

# ============================================
# AddLiquidity.s.sol — Step 2: PancakeSwap LP
# ============================================
# Fill these AFTER running AirdropMint (use the deployed addresses from output)
PGVT_ADDRESS=0x_deployed_pgvt_address
SGVT_ADDRESS=0x_deployed_sgvt_address

# ============================================
# Existing Presale Deployment (DeployPresale.s.sol)
# ============================================
TREASURY_ADDRESS=0x_treasury_address
USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955  # BSC USDT