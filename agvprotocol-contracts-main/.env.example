# ============================================================
# V3 Pass Deployment — BSC Mainnet
# ============================================================
# Usage:
#   cp .env.example .env   →  fill in values  →  run:
#
#   forge script script/DeployPasses.s.sol:DeployPasses \
#     --rpc-url $BSC_RPC_URL \
#     --broadcast --verify \
#     --etherscan-api-key $BSCSCAN_API_KEY -vvvv
# ============================================================

# Deployer private key (with 0x prefix)
PRIVATE_KEY=

# AccessControl admin — receives ADMIN_ROLE + DEFAULT_ADMIN_ROLE
ADMIN_ADDRESS=

# USDT payment receiver for mint()
TREASURY_ADDRESS=

# BSC USDT — optional, script defaults to 0x55d398326f99059fF775485246999027B3197955
# BSC_USDT=0x55d398326f99059fF775485246999027B3197955

# ============================================================
# Network
# ============================================================
BSC_RPC_URL=https://bsc-dataseed1.binance.org

# ============================================================
# Verification
# ============================================================
BSCSCAN_API_KEY=
